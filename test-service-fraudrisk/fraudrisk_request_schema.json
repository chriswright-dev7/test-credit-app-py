{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "app": {
      "type": "object",
      "properties": {
        "appId": { "type": ["string", "null"] },
        "sessionId": { "type": "string", "format": "uuid" },
        "decisionCode": { "type": ["string", "null"] },

        "creditInfo": {
          "type": "object",
          "properties": {
            "firstName": { "type": "string" },
            "middleInitial": { "type": "string", "maxLength": 1 },
            "lastName": { "type": "string" },
            "DOB": { "type": "string" },
            "SSN": { "type": "string", "pattern": "^\\d{9}$" },
            "email": { "type": "string", "format": "email" },
            "phoneNumber": { "type": "string" },
            "address": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string", "minLength": 2, "maxLength": 2 },
            "zip": { "type": "string", "pattern": "^\\d{5}$" },
            "annualIncome": { "type": ["number", "string"] }
          },
          "required": [
            "firstName",
            "lastName",
            "DOB",
            "SSN",
            "email",
            "phoneNumber",
            "address",
            "city",
            "state",
            "zip"
          ],
          "additionalProperties": true
        }
      },
      "required": ["sessionId", "creditInfo", "decisionCode", "appId"],
      "additionalProperties": true
    }
  },
  "required": ["app"],
  "additionalProperties": false
}